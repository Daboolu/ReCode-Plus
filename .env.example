DATABASE_URL="file:./dev.db"

# Agent provider: "ollama" or "openai-compatible"
AGENT_PROVIDER="ollama"

# Local Agent (default)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5-coder:7b"

# Remote OpenAI-compatible API. Used only when AGENT_PROVIDER="openai-compatible".
# Include the API version prefix (commonly /v1), but not /chat/completions.
AGENT_BASE_URL="https://your-provider.example/v1"
AGENT_API_KEY=""
AGENT_MODEL=""
AGENT_TIMEOUT_SECONDS="120"

# Set to true to develop the Agent UI without Ollama or a downloaded model.
AGENT_MOCK_MODE="false"
